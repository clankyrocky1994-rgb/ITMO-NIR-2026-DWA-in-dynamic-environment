<mujoco model="tidybot scene">
  <include file="tidybot.xml"/>

  <statistic center="0.25 0 0.6" extent="8.0" meansize="0.05"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient"
             rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>

    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>

    <material name="groundplane" texture="groundplane"
              texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <material name="wall_mat" rgba="0.2 0.2 0.2 1"/>
    <material name="obstacle_mat" rgba="0.2 0.2 0.8 1"/>
    <material name="goal_mat" rgba="1 0 0 0.6"/>
  </asset>

<worldbody>
  <light pos="0 0 3.0" directional="true"/>

  <geom name="floor"
        size="0 0 0.05"
        type="plane"
        material="groundplane"/>

  <!-- mocap target для старой IK-логики -->
  <body name="pinch_site_target"
        pos="-2.4 -6.0 0.75"
        quat="0 1 0 0"
        mocap="true">
    <geom type="box"
          size="0.05 0.05 0.05"
          contype="0"
          conaffinity="0"
          rgba="0.6 0.3 0.3 0.25"/>
  </body>

  <!-- красная зона цели 0.3 x 0.3 м -->
<!-- Goal zone: shifted to the right after the turn -->
<geom name="goal_zone"
      type="box"
      pos="1.35 4.75 0.006"
      size="0.15 0.15 0.005"
      rgba="1 0 0 0.65"
      contype="0"
      conaffinity="0"/>

<!-- First part: old-style obstacle row along the robot path -->

<body name="obs1" pos="-2.40 -4.40 0.35">
  <geom name="obs1_geom"
        type="cylinder"
        size="0.09 0.35"
        rgba="0.2 0.2 0.8 1"/>
</body>

<body name="obs2" pos="-1.75 -3.20 0.35">
  <geom name="obs2_geom"
        type="cylinder"
        size="0.09 0.35"
        rgba="0.2 0.2 0.8 1"/>
</body>

<body name="obs3" pos="-2.70 -2.00 0.35">
  <geom name="obs3_geom"
        type="cylinder"
        size="0.09 0.35"
        rgba="0.2 0.2 0.8 1"/>
</body>

<body name="obs4" pos="-1.75 -0.80 0.35">
  <geom name="obs4_geom"
        type="cylinder"
        size="0.09 0.35"
        rgba="0.2 0.2 0.8 1"/>
</body>

<body name="obs5" pos="-2.70 0.60 0.35">
  <geom name="obs5_geom"
        type="cylinder"
        size="0.09 0.35"
        rgba="0.2 0.2 0.8 1"/>
</body>

<!-- obstacle near the right turn -->
<body name="obs6" pos="-0.35 1.85 0.35">
  <geom name="obs6_geom"
        type="cylinder"
        size="0.08 0.35"
        rgba="0.2 0.2 0.8 1"/>
</body>

<!-- obstacle on the final approach -->
<body name="obs7" pos="1.25 3.25 0.35">
  <geom name="obs7_geom"
        type="cylinder"
        size="0.08 0.35"
        rgba="0.2 0.2 0.8 1"/>
</body>

  <!-- стены -->
  <!-- left wall of the first straight corridor -->
<!-- ===================== -->
<!-- WIDE L-SHAPED CORRIDOR -->
<!-- ===================== -->

<!-- bottom wall behind robot -->
<geom name="corridor_start_end"
      type="box"
      pos="-2.40 -6.85 0.60"
      size="1.35 0.08 0.60"
      rgba="0.15 0.15 0.15 1"/>

<!-- left wall of first vertical corridor -->
<geom name="corridor_left_1"
      type="box"
      pos="-3.65 -2.00 0.60"
      size="0.08 4.95 0.60"
      rgba="0.15 0.15 0.15 1"/>

<!-- right wall of first vertical corridor, stops before the turn -->
<geom name="corridor_right_1"
      type="box"
      pos="-1.15 -3.05 0.60"
      size="0.08 3.90 0.60"
      rgba="0.15 0.15 0.15 1"/>

<!-- upper wall of the right turn -->
<geom name="corridor_turn_top"
      type="box"
      pos="-1.70 2.85 0.60"
      size="2.05 0.08 0.60"
      rgba="0.15 0.15 0.15 1"/>

<!-- lower wall of the right turn -->
<geom name="corridor_turn_bottom"
      type="box"
      pos="0.65 0.75 0.60"
      size="1.90 0.08 0.60"
      rgba="0.15 0.15 0.15 1"/>

<!-- left wall of final vertical corridor -->
<geom name="corridor_left_2"
      type="box"
      pos="0.25 4.10 0.60"
      size="0.08 1.35 0.60"
      rgba="0.15 0.15 0.15 1"/>

<!-- right wall of final vertical corridor -->
<geom name="corridor_right_2"
      type="box"
      pos="2.45 3.05 0.60"
      size="0.08 2.40 0.60"
      rgba="0.15 0.15 0.15 1"/>

<!-- end wall behind goal -->
<geom name="corridor_goal_end"
      type="box"
      pos="1.35 5.35 0.60"
      size="1.25 0.08 0.60"
      rgba="0.15 0.15 0.15 1"/>
</worldbody>
</mujoco>